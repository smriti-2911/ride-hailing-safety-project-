# Copy to .env and fill in. Never commit .env.

JWT_SECRET_KEY=change-me-to-a-long-random-string-in-production

# Optional: PostgreSQL in production (Render/Railway). If unset, SQLite is used under instance/
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

GOOGLE_MAPS_API_KEY=your-google-maps-key

# Twilio — Account SID must be exactly 34 characters (AC + 32 hex digits)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
